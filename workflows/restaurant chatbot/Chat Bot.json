    {
      "parameters": {
        "jsCode": "const response = $input.first().json.output;\n\n// Try to extract [BOOKING_DATA] block\nconst match = response.match(/\\[BOOKING_DATA\\]([\\s\\S]*?)\\[\\/BOOKING_DATA\\]/);\n\nif (match) {\n  // Clean the AI reply — remove the BOOKING_DATA block from visible reply\n  const cleanReply = response.replace(/\\[BOOKING_DATA\\][\\s\\S]*?\\[\\/BOOKING_DATA\\]/, '').trim();\n  \n  // Parse the booking JSON\n  let bookingData = {};\n  try {\n    bookingData = JSON.parse(match[1].trim());\n  } catch(e) {\n    bookingData = { booking_complete: false };\n  }\n\n  return [{\n    json: {\n      reply: cleanReply,\n      booking_complete: true,\n      booking: bookingData\n    }\n  }];\n}\n\n// No booking data found — just pass through the reply\nreturn [{\n  json: {\n    reply: response,\n    booking_complete: false,\n    booking: {}\n  }\n}];"
      },
