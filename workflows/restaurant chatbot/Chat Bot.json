    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst combined = items\n  .filter(item => \n    item.json.content !== null && \n    item.json.content !== 'null' && \n    item.json.content !== '' &&\n    item.json.content?.trim() !== '' &&\n    !item.json.content?.includes('[BOOKING_DATA]')\n  )\n  .map(item => item.json.content.trim())\n  .join('\\n\\n');\nreturn [{ json: { message_history: combined } }];"
      },
