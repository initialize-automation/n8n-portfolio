    {
      "parameters": {
        "jsCode": "const allRows = [];\n\nfor (const item of $input.all()) {\n  let rawdata = null;\n  \n  // Handle string output (AI returned JSON as text)\n  if (typeof item.json.output === 'string') {\n    try {\n      // Remove markdown code blocks if present\n      const cleaned = item.json.output\n        .replace(/```json/g, '')\n        .replace(/```/g, '')\n        .trim();\n      const parsed = JSON.parse(cleaned);\n      rawdata = Array.isArray(parsed) ? parsed : parsed.rawdata;\n    } catch(e) {\n      // skip this item if parsing fails\n    }\n  } else if (item.json?.output?.rawdata) {\n    rawdata = item.json.output.rawdata;\n  }\n\n  if (Array.isArray(rawdata)) {\n    rawdata.forEach(row => allRows.push({ json: row }));\n  }\n}\n\nreturn allRows;"
      },
